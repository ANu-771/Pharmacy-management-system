<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.pharmacy.controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #1e3a8a;">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>

            <Label fx:id="lblTitle" text="Pharmacy Management System" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" /> <VBox alignment="CENTER_RIGHT">
            <Label text="Logged in as: Admin" textFill="WHITE">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
            <Label text="Date: 2025-01-01" textFill="#cbd5e1">
                <font>
                    <Font size="12.0" />
                </font>
            </Label>
        </VBox>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="240.0" spacing="10.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <Label text="MAIN MENU" textFill="#64748b">
                <font>
                    <Font name="System Bold" size="12.0" />
                </font>
            </Label>

            <Separator prefWidth="200.0" />

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-alignment: CENTER_LEFT; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5;" text="Dashboard" textFill="#1e293b">
                <font><Font size="14.0" /></font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-alignment: CENTER_LEFT; -fx-background-color: transparent;" text="Customers" textFill="#334155">
                <font><Font size="14.0" /></font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-alignment: CENTER_LEFT; -fx-background-color: transparent;" text="Medicines" textFill="#334155">
                <font><Font size="14.0" /></font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-alignment: CENTER_LEFT; -fx-background-color: transparent;" text="Suppliers" textFill="#334155">
                <font><Font size="14.0" /></font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-alignment: CENTER_LEFT; -fx-background-color: transparent;" text="Sales Order" textFill="#334155">
                <font><Font size="14.0" /></font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-alignment: CENTER_LEFT; -fx-background-color: transparent;" text="Reports" textFill="#334155">
                <font><Font size="14.0" /></font>
            </Button>

            <Region VBox.vgrow="ALWAYS" /> <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #fee2e2; -fx-text-fill: #dc2626; -fx-background-radius: 5;" text="Logout">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: white;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <Label text="Dashboard Overview" textFill="#1e293b">
                <font>
                    <Font name="System Bold" size="22.0" />
                </font>
            </Label>

            <HBox spacing="20.0">

                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #e0f2fe; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label text="Total Medicines" textFill="#0369a1">
                        <font><Font size="16.0" /></font>
                    </Label>
                    <Label text="1,240">
                        <font><Font name="System Bold" size="32.0" /></font>
                    </Label>
                    <Label text="+5 New Items" textFill="#0284c7">
                        <font><Font size="12.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #dcfce7; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label text="Active Customers" textFill="#15803d">
                        <font><Font size="16.0" /></font>
                    </Label>
                    <Label text="85">
                        <font><Font name="System Bold" size="32.0" /></font>
                    </Label>
                    <Label text="+2 Today" textFill="#16a34a">
                        <font><Font size="12.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #fef3c7; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label text="Today's Income" textFill="#b45309">
                        <font><Font size="16.0" /></font>
                    </Label>
                    <Label text="Rs. 45k">
                        <font><Font name="System Bold" size="32.0" /></font>
                    </Label>
                    <Label text="Target: 50k" textFill="#d97706">
                        <font><Font size="12.0" /></font>
                    </Label>
                </VBox>
            </HBox>

            <Separator />

            <VBox style="-fx-background-color: #f8fafc; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <Label text="Recent Transactions" textFill="#475569">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
                <Label text="(Table Placeholder)" textFill="#94a3b8" />
            </VBox>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="30.0" style="-fx-background-color: #e2e8f0;">
            <Label text="© 2025 Pharmacy Management System | v1.0.0" textFill="#64748b">
                <font>
                    <Font size="11.0" />
                </font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
